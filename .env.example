# Copie para .env na raiz do projeto:
#   cp .env.example .env
#
# Usado por docker-compose.yml (Evolution API + Postgres local).
# Nunca commite o arquivo .env — ele já está no .gitignore.

# PostgreSQL (serviço postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=evolution

# Evolution API (serviço evolution-api)
EVOLUTION_API_KEY=
