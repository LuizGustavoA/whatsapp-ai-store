# Banco de dados
DB_USER=postgres
DB_HOST=localhost
DB_NAME=whatsapp_ai_store
DB_PASSWORD=
DB_PORT=5432

# Servidor
PORT=3000
CORS_ORIGIN=*
JWT_SECRET=altere-esta-chave

# WhatsApp Meta Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Opcional: só esses números acionam o chatbot (vírgula). Vazio = todos.
WHATSAPP_BOT_ALLOWED_NUMBERS=

# IA do chatbot — OpenRouter (grátis) OU OpenAI (pago)
# OpenRouter tem prioridade se OPENROUTER_API_KEY estiver preenchida
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_JSON_MODE=true  # só se o modelo suportar JSON mode na API

# OpenAI (alternativa paga; usada só se OPENROUTER_API_KEY estiver vazia)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LLM_TEMPERATURE=0.65

# Loja / chatbot
STORE_NAME=Minha Loja
STORE_HOURS=11:00-01:00
STORE_DELIVERY_FEE=R$ 5,00
STORE_DELIVERY_AREA=Centro e bairros próximos
STORE_ESTIMATED_PREP_MINUTES=35
STORE_PAYMENT_METHODS=PIX pelo WhatsApp. No salão: dinheiro, débito, crédito e PIX.
STORE_TIMEZONE=America/Sao_Paulo
STORE_ALWAYS_OPEN=false
SKIP_PAYMENT_CONFIRMATION=false
CHAT_RESTRICT_OFF_TOPIC=true

# Cardápio em imagem (WhatsApp exige URL pública HTTPS)
# Opção 1: URL direta da imagem hospedada
MENU_IMAGE_URL=
# Opção 2: coloque cardapio.jpg em backend/public/ e use a URL pública do servidor
PUBLIC_BASE_URL=

# PIX — Mercado Pago (recomendado) ou estático
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PAYER_EMAIL=cliente@loja.com
PIX_KEY=
PIX_MERCHANT_NAME=Minha Loja
PIX_MERCHANT_CITY=SAO PAULO

# Cashback
CASHBACK_RATE=0.05

# N8N (opcional)
N8N_WEBHOOK_ORDER_CREATED=
N8N_WEBHOOK_ORDER_PAID=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
